---
export interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="mb-8">
  {eyebrow && <p class="text-sm uppercase tracking-[0.3em] text-cyan-300">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-semibold text-white">{title}</h2>
  {text && <p class="mt-3 max-w-2xl text-slate-300">{text}</p>}
</div>
