---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { publications } from "../data/publications";
---

<BaseLayout title="Publications">
  <section class="mx-auto max-w-4xl px-6 py-24">
    <SectionHeading
      eyebrow="Writing"
      title="Publications"
      text="A low-key timeline list for papers, preprints, workshops, and research outputs."
    />

    <div class="space-y-6">
      {publications.map((item) => (
        <a href={item.link} class="block rounded-3xl border border-white/10 bg-white/5 p-6">
          <p class="text-sm uppercase tracking-[0.2em] text-cyan-300">{item.year}</p>
          <h3 class="mt-2 text-xl font-semibold text-white">{item.title}</h3>
          <p class="mt-2 text-slate-300">{item.authors}</p>
          <p class="mt-1 text-slate-400">{item.venue}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
