---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { projects } from "../data/projects";
---

<BaseLayout title="Projects">
  <section class="mx-auto max-w-6xl px-6 py-24">
    <SectionHeading
      eyebrow="Builds"
      title="Projects"
      text="A browsable set of work across research, design, ML, and experimentation."
    />

    <input
      id="project-search"
      type="text"
      placeholder="Search projects..."
      class="mb-8 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-slate-100 outline-none placeholder:text-slate-500"
    />

    <div id="project-grid" class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={project.link}
          class="project-card rounded-3xl border border-white/10 bg-white/5 p-6"
          data-search={`${project.title} ${project.summary} ${project.tags.join(" ")}`.toLowerCase()}
        >
          <h3 class="text-xl font-semibold text-white">{project.title}</h3>
          <p class="mt-3 text-slate-300">{project.summary}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const input = document.querySelector<HTMLInputElement>('#project-search');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.project-card'));

    input?.addEventListener('input', () => {
      const value = input.value.toLowerCase();

      cards.forEach((card) => {
        const text = card.dataset.search ?? '';
        card.style.display = text.includes(value) ? '' : 'none';
      });
    });
  </script>
</BaseLayout>
