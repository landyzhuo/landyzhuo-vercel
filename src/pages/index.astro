---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../data/site";
import { projects } from "../data/projects";
---

<BaseLayout title="Home">
  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-cyan-300">Landy Zhuo</p>
        <h1 class="mt-4 text-5xl font-semibold tracking-tight text-white sm:text-6xl">
          {site.headline}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
          {site.bio}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/projects" class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-medium text-slate-950">
            View Projects
          </a>
          <a href="/contact" class="rounded-full border border-white/15 px-5 py-3 text-sm text-slate-200">
            Contact
          </a>
        </div>
      </div>

      <aside class="rounded-3xl border border-white/10 bg-white/5 p-8">
        <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Focus Areas</p>
        <ul class="mt-6 space-y-3 text-slate-200">
          {site.interests.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-8">
    <SectionHeading
      eyebrow="Featured Work"
      title="Selected projects"
      text="A first pass at your portfolio content, ready to be replaced with your real work."
    />
    <div class="grid gap-6 md:grid-cols-2">
      {projects.slice(0, 2).map((project) => (
        <a href={project.link} class="rounded-3xl border border-white/10 bg-white/5 p-6 transition hover:border-cyan-300/40 hover:bg-white/10">
          <h3 class="text-xl font-semibold text-white">{project.title}</h3>
          <p class="mt-3 text-slate-300">{project.summary}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
